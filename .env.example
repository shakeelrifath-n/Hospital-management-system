# ====================================
# Hospital Management System Configuration
# Environment Variables (.env.example)
# ====================================
# COPY THIS FILE TO .env AND CUSTOMIZE FOR YOUR ENVIRONMENT
# DO NOT COMMIT .env FILE TO GIT (add to .gitignore)

# Database Configuration
# ========================
# Root password for MySQL admin user
DB_ROOT_PASSWORD=password123

# Database name to create/use
DB_NAME=hms

# Application database user (created by MySQL init)
DB_USER=admin

# Application database user password
DB_PASSWORD=password123

# Backend Service Configuration
# ===============================
# Port where Spring Boot backend runs (inside Docker container)
BACKEND_PORT=8080

# Hostname of backend service (use 'backend' for Docker service discovery)
BACKEND_HOST=backend

# Frontend Service Configuration
# ================================
# Port where Nginx serves the frontend (exposed to host)
FRONTEND_PORT=80

# API Configuration
# ====================
# Base URL for API requests from Angular frontend
# 
# Options:
#   /api              - Use internal Nginx proxy (recommended for containerized deployment)
#   localhost:8080    - Direct to backend (dev only, will fail in browser due to CORS/ports)
#   https://api.example.com - External backend URL (production with separate backend server)
API_BASE_URL=/api

# Spring Boot Configuration
# ============================
# Show SQL queries in logs (true/false)
SPRING_JPA_SHOW_SQL=false

# Hibernate auto schema generation (validate, update, create, create-drop)
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Timezone (UTC recommended for consistency)
TZ=UTC

# Environment Type
# ==================
# Used to configure features/logging based on deployment environment
# Options: development, staging, production
ENVIRONMENT=development

# ====================================
# PRODUCTION RECOMMENDATIONS
# ====================================
# 1. Change all passwords to strong values:
#    Example: aB3$xY9@mK2#pL7&qR5*vW8!nJ4%tC6^
# 
# 2. Set ENVIRONMENT=production
#
# 3. Use API_BASE_URL with HTTPS:
#    API_BASE_URL=https://api.yourdomain.com
#
# 4. Set SPRING_JPA_SHOW_SQL=false (hide queries in production logs)
#
# 5. Store .env file securely (never commit to Git)
#
# 6. Use secrets management (AWS Secrets Manager, HashiCorp Vault, etc.)
